{
  "version": "0.1.0",
  "name": "delta_vault",
  "instructions": [
    {
      "name": "initializeVault",
      "accounts": [
        { "name": "vaultState",    "isMut": true,  "isSigner": false },
        { "name": "authority",     "isMut": true,  "isSigner": true  },
        { "name": "usdcMint",      "isMut": false, "isSigner": false },
        { "name": "shareMint",     "isMut": true,  "isSigner": false },
        { "name": "systemProgram", "isMut": false, "isSigner": false },
        { "name": "tokenProgram",  "isMut": false, "isSigner": false },
        { "name": "rent",          "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "params", "type": { "defined": "VaultParams" } }
      ]
    },
    {
      "name": "deposit",
      "accounts": [
        { "name": "vaultState",    "isMut": true,  "isSigner": false },
        { "name": "depositor",     "isMut": true,  "isSigner": true  },
        { "name": "systemProgram", "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "amountUsdc", "type": "u64" }
      ]
    },
    {
      "name": "withdraw",
      "accounts": [
        { "name": "vaultState",    "isMut": true,  "isSigner": false },
        { "name": "depositor",     "isMut": true,  "isSigner": true  },
        { "name": "systemProgram", "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "shares", "type": "u64" }
      ]
    },
    {
      "name": "updateNav",
      "accounts": [
        { "name": "vaultState", "isMut": true,  "isSigner": false },
        { "name": "bot",        "isMut": false, "isSigner": true  }
      ],
      "args": [
        { "name": "btcPriceUsdc", "type": "u64" },
        { "name": "ethPriceUsdc", "type": "u64" },
        { "name": "perpPnl",      "type": "i64" },
        { "name": "spotBtc",      "type": "u64" },
        { "name": "spotEth",      "type": "u64" }
      ]
    },
    {
      "name": "updateStrategy",
      "accounts": [
        { "name": "vaultState",    "isMut": false, "isSigner": false },
        { "name": "strategyState", "isMut": true,  "isSigner": false },
        { "name": "riskOracle",    "isMut": false, "isSigner": false },
        { "name": "bot",           "isMut": true,  "isSigner": true  },
        { "name": "systemProgram", "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "mode", "type": { "defined": "StrategyMode" } }
      ]
    },
    {
      "name": "assertRiskOk",
      "accounts": [
        { "name": "vaultState", "isMut": false, "isSigner": false },
        { "name": "riskOracle", "isMut": false, "isSigner": false }
      ],
      "args": []
    },
    {
      "name": "updateRiskOracle",
      "accounts": [
        { "name": "riskOracle",    "isMut": true,  "isSigner": false },
        { "name": "vaultState",    "isMut": false, "isSigner": false },
        { "name": "bot",           "isMut": true,  "isSigner": true  },
        { "name": "systemProgram", "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "drawdownBps",     "type": "u16" },
        { "name": "deltaBps",        "type": "u16" },
        { "name": "executionPaused", "type": "u8"  }
      ]
    },
    {
      "name": "collectFees",
      "accounts": [
        { "name": "vaultState",    "isMut": true,  "isSigner": false },
        { "name": "bot",           "isMut": true,  "isSigner": true  },
        { "name": "systemProgram", "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "feeCollector", "type": "publicKey" }
      ]
    }
  ],
  "accounts": [
    {
      "name": "VaultState",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "authority",             "type": "publicKey" },
          { "name": "usdcMint",              "type": "publicKey" },
          { "name": "shareMint",             "type": "publicKey" },
          { "name": "usdcBalance",           "type": "u64" },
          { "name": "spotBtcAmount",         "type": "u64" },
          { "name": "spotEthAmount",         "type": "u64" },
          { "name": "perpUnrealizedPnl",     "type": "i64" },
          { "name": "borrowedUsdc",          "type": "u64" },
          { "name": "cachedNavPerShare",     "type": "u64" },
          { "name": "navLastUpdated",        "type": "i64" },
          { "name": "peakNavPerShare",       "type": "u64" },
          { "name": "totalShares",           "type": "u64" },
          { "name": "highWaterMark",         "type": "u64" },
          { "name": "authorizedBot",         "type": "publicKey" },
          { "name": "pendingBot",            "type": "publicKey" },
          { "name": "rotationEffectiveTime", "type": "i64" },
          { "name": "params",                "type": { "defined": "VaultParams" } },
          { "name": "bump",                  "type": "u8" }
        ]
      }
    },
    {
      "name": "RiskOracle",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "vault",           "type": "publicKey" },
          { "name": "drawdownBps",     "type": "u16" },
          { "name": "deltaBps",        "type": "u16" },
          { "name": "executionPaused", "type": "u8" },
          { "name": "lastUpdated",     "type": "i64" },
          { "name": "bump",            "type": "u8" }
        ]
      }
    },
    {
      "name": "StrategyState",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "vault",          "type": "publicKey" },
          { "name": "currentMode",    "type": { "defined": "StrategyMode" } },
          { "name": "lastUpdated",    "type": "i64" },
          { "name": "authorizedBot",  "type": "publicKey" },
          { "name": "btcPerpPosition","type": "i64" },
          { "name": "ethPerpPosition","type": "i64" },
          { "name": "bump",           "type": "u8" }
        ]
      }
    }
  ],
  "types": [
    {
      "name": "VaultParams",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "managementFeeBps",      "type": "u16" },
          { "name": "performanceFeeBps",     "type": "u16" },
          { "name": "maxDrawdownBps",        "type": "u16" },
          { "name": "maxDeltaBps",           "type": "u16" },
          { "name": "minDepositUsdc",        "type": "u64" },
          { "name": "navConfidenceBufferBps","type": "u16" },
          { "name": "maxNavStalenessS",      "type": "i64" }
        ]
      }
    },
    {
      "name": "StrategyMode",
      "type": {
        "kind": "enum",
        "variants": [
          { "name": "DeltaNeutral"  },
          { "name": "BasisTrade"   },
          { "name": "ParkCapital"  },
          { "name": "EmergencyStop"}
        ]
      }
    }
  ],
  "errors": [
    { "code": 6000, "name": "NavNotFound",         "msg": "NAV oracle not initialized" },
    { "code": 6001, "name": "InsufficientFunds",   "msg": "Insufficient funds" },
    { "code": 6002, "name": "BelowMinDeposit",     "msg": "Below minimum deposit" },
    { "code": 6003, "name": "NavStale",            "msg": "NAV too stale — update NAV first" },
    { "code": 6004, "name": "MathOverflow",        "msg": "Math overflow" },
    { "code": 6005, "name": "ExceedsMaxDrawdown",  "msg": "Drawdown limit breached" },
    { "code": 6006, "name": "ExceedsMaxDelta",     "msg": "Delta exposure limit breached" },
    { "code": 6007, "name": "FeeEpochNotElapsed",  "msg": "Fee epoch has not elapsed" },
    { "code": 6008, "name": "UnauthorizedBot",     "msg": "Only authorized bot may call this instruction" },
    { "code": 6009, "name": "TimelockNotElapsed",  "msg": "Timelock has not elapsed" },
    { "code": 6010, "name": "InvalidOracle",       "msg": "Risk oracle does not match vault" },
    { "code": 6011, "name": "ExecutionPaused",     "msg": "Execution is paused" }
  ],
  "metadata": {
    "address": "2g9eqiJXmGkJARi7Sgmk3U5Fy7KRdAwPonuMeYyouAEr"
  }
}
