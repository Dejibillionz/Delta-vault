# ─── Mode ────────────────────────────────────────────────────────────────────
DEMO_MODE=true                     # true = no real orders (safe default)
DEMO_EQUITY=10000                  # starting equity shown in demo mode ($)

# ─── Network ─────────────────────────────────────────────────────────────────
SOLANA_NETWORK=devnet              # devnet | mainnet-beta
HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY

# ─── Solana Wallet ────────────────────────────────────────────────────────────
# Provide ONE of the two options below:
WALLET_PRIVATE_KEY_BASE58=         # base58-encoded Solana private key
WALLET_KEYPAIR_PATH=               # OR path to keypair JSON file

# ─── Hyperliquid (perp execution + funding data) ─────────────────────────────
EVM_PRIVATE_KEY=                   # EVM private key for HL order signing
HYPERLIQUID_API_URL=https://api.hyperliquid.xyz

# ─── Kamino Finance (USDC lending yield) ─────────────────────────────────────
KAMINO_MARKET_ADDRESS=             # optional — demo mode used if unset
KAMINO_USDC_RESERVE_ADDRESS=       # Kamino USDC reserve address (e.g. d4A2prbA2whesmvHaL88BH6Ewn5N4bJ6L7EBHrKnPmj)
KAMINO_SIM_APR=0.045               # simulated supply APR (4.5%) used in demo / fallback mode

# ─── MarginFi (borrow leg for negative-funding hedge) ────────────────────────
MARGINFI_ENV=development           # development (devnet) | production (mainnet)

# ─── Anchor On-Chain Program ─────────────────────────────────────────────────
VAULT_PROGRAM_ID=2g9eqiJXmGkJARi7Sgmk3U5Fy7KRdAwPonuMeYyouAEr

# ─── Strategy ────────────────────────────────────────────────────────────────
TRADING_ASSETS=BTC,ETH,SOL,JTO    # fallback assets (used if SCANNER_ENABLED=false)
AI_AGENT_ENABLED=true              # false to disable the statistical AI advisor

# ─── Funding Rate Scanner (dynamic asset selection) ───────────────────────────
SCANNER_ENABLED=true               # scan all 229 HL markets, pick top N
SCANNER_TOP_N=6                    # number of assets to trade simultaneously
SCANNER_MIN_DAILY_VOLUME_USD=5000000   # safety filter: $5M minimum 24h volume
SCANNER_MIN_OI_USD=1000000             # safety filter: $1M minimum open interest
SCANNER_RANK_INTERVAL_MS=300000        # 300s = re-rank every 5 minutes
SCANNER_MAX_DRAIN_MS=7200000           # 2h max wait for open positions to drain
SCANNER_BLACKLIST=                     # comma-separated assets to always exclude (e.g. LUNA,TRUMP)

# ─── Market Impact Limits ─────────────────────────────────────────────────────
# Cap each trade to a fraction of the market's liquidity to avoid moving prices.
MARKET_IMPACT_VOLUME_PCT=0.001    # max trade = 0.1% of 24h perp volume (e.g. $20M vol → $20K cap)
MARKET_IMPACT_OI_PCT=0.005        # max trade = 0.5% of open interest (e.g. $40M OI → $200K cap)

# ─── Risk Limits ──────────────────────────────────────────────────────────────
FUNDING_CIRCUIT_BREAKER_APR=3.0   # block new entries when |funding APR| > 300% (extreme rate)
MAX_GROSS_NOTIONAL_RATIO=1.5      # total spot+perp notional ≤ 1.5× equity

# ─── Bybit (optional second venue for cross-venue funding arb) ────────────────
BYBIT_API_KEY=                    # Bybit V5 API key (leave blank to disable)
BYBIT_API_SECRET=                 # Bybit V5 API secret
BYBIT_ARB_MIN_SPREAD_APR=0.02     # route to Bybit only when its APR > HL + 2%
MAX_SLIPPAGE_PCT=0.003            # abort trade if perp fill slippage exceeds 0.3%

# ─── Phase 5 Refinements ─────────────────────────────────────────────────────
SCORE_POWER=1.3                    # power-law exponent for score weighting (1.0 = linear)
SLIPPAGE_WARN_PCT=0.003            # tier-1 slippage: pause pair for N cycles (keeps position)
SLIPPAGE_ABORT_PCT=0.005           # tier-2 slippage: unwind immediately
SLIPPAGE_PAUSE_CYCLES=5            # cycles to pause pair after tier-1 slippage warning
AUTO_HALT_1H_PCT=0.02              # auto-halt when 1h drawdown exceeds 2%
AUTO_HALT_24H_PCT=0.05             # auto-halt when 24h drawdown exceeds 5%
AUTO_HALT_HL_LATENCY_MS=5000       # auto-halt when HL API latency exceeds 5s
AUTO_HALT_CLEAR_CYCLES=12          # consecutive stable risk cycles before auto-resume (12×10s = 2min)
AUTO_HALT_ATR_RATIO=1.5            # BTC ATR must be < ATR_TARGET × ratio before resume (1.5 = 3% target → 4.5% max)
AUTO_HALT_LATENCY_SEVERE_MULT=2.0  # latency > threshold × this = severe, triggers extended cooldown
AUTO_HALT_LATENCY_SEVERE_EXTRA=6   # extra stable cycles required after severe latency breach (+1 min)
AUTO_HALT_DELTA_GATE_PCT=0.05      # net delta drift must be ≤ 5% before resume
AUTO_HALT_EXPOSURE_GATE_PCT=0.65   # (spot+perp) / equity must be ≤ 65% before resume
AUTO_HALT_MIN_EDGE_APR=0.005       # best net funding edge across assets must be ≥ 0.5% APR (converted to hourly internally)
AUTO_HALT_FEE_EST_APR=0.003        # estimated annual fee cost subtracted from edge (slippage + protocol)
AUTO_HALT_CORR_THRESHOLD=0.75      # avg pairwise portfolio corr above this = systemic risk
AUTO_HALT_CORR_EXPOSURE_CAP=0.50   # tightened exposure cap during high-correlation regimes
ATR_COMPRESSION_FLOOR=0.003        # BTC ATR below this = suspicious ultra-low volatility → extended streak
AUTO_HALT_CLEAR_CYCLES_COMPRESSED=18 # cycles required when ATR is suspiciously compressed (18×10s=3min)
POST_HALT_PHASE1_CAP=0.30          # exposure cap immediately after auto-halt lifts (first 5 min)
POST_HALT_PHASE2_CAP=0.50          # exposure cap in phase 2 (5-15 min after resume)
POST_HALT_PHASE1_MS=300000         # duration of phase 1 in ms (5 min)
POST_HALT_PHASE2_MS=900000         # duration of phase 2 in ms (15 min total from resume)

# ─── Funding Persistence Predictor (FPP) ─────────────────────────────────────
FPP_MIN_PERSISTENCE=0.45           # block new entries when persistenceScore < this
FPP_SIZING_FLOOR=0.50              # sizing floor: actual mult = FLOOR + (1-FLOOR)×score
FPP_RING_SIZE=20                   # funding history depth (samples)
FPP_SLOPE_WINDOW=5                 # samples over which funding slope is computed
FPP_K_INTERVALS=4                  # forward projection intervals for expectedEdge
FPP_SIGMOID_SCALE=0.00002          # sigmoid scale for trend score (hourly-rate units)
FPP_OI_SCORE_CAP=0.05              # OI change % that maps to oiScore = 1.0
FPP_OI_DIVERGE_THRESH=0.03         # OI drop % that triggers OI-divergence kill (×0.3)
FPP_ATR_CONFLICT_MULT=2.0          # ATR_TARGET × this = atr conflict threshold (×0.5)
ATR_TARGET_VOL_PCT=0.02            # ATR baseline: no penalty below 2% price stdDev

# ─── Funding Regime Classifier + Exit Timing Model (FRC/ETM) ─────────────────
FRC_RING_SIZE=20                   # funding history depth for z-score computation
FRC_SLOPE_WINDOW=5                 # samples used for funding slope calculation
FRC_HIGH_Z=1.5                     # z-score above which funding is flagged as PEAK
FRC_PEAK_EARLY_Z=1.2               # z-score above which (+ deceleration) → PEAK_EARLY (entry blocked)
FRC_EXPANSION_ENTER=0.65           # persistence threshold to ENTER EXPANSION from ACCUMULATION (hysteresis hi)
FRC_EXPANSION_EXIT=0.55            # persistence threshold to EXIT EXPANSION back to ACCUMULATION (hysteresis lo)
FRC_REDUCE_COOLDOWN_CYCLES=3       # strategy cycles to block re-entry after REDUCE_50 (3 × 15s = 45s)
FRC_REDUCE_COOLDOWN_LONG=5         # extended cooldown cycles when raw exitScore ≥ 0.65 (5 × 15s = 75s)
FRC_PERSIST_FULL_SIZE_OVERRIDE=0.59 # ACCUMULATION dead-band override: full size when persistence ≥ this
FRC_PERSIST_OVERRIDE_REENTRY_BLOCK=2 # cycles to block re-activation of sizing override after regime-departure reset
ETM_EXIT_FULL=0.7                  # exitScoreSmoothed threshold for FULL_EXIT
ETM_EXIT_PARTIAL=0.5               # exitScoreSmoothed threshold for REDUCE_50
ETM_PERSIST_DROP_WINDOW=3          # ring depth for persistence-drop detection
ETM_EMA_ALPHA=0.2                  # EMA smoothing factor for exitScore (α=0.2 → ~75s window at 15s cycles)
ETM_SLOPE_NORM=0.0001              # slope normalizer (value at which negSlope = 1.0)
ETM_OI_NORM=0.05                   # OI change normalizer (5% OI drop → negOi = 1.0)
ETM_PEAK_EARLY_BIAS=0.1            # soft exit pressure in PEAK_EARLY: effectiveScore += 0.1
ETM_SPIKE_OVERRIDE_THRESH=0.9      # raw exitScore above this → FULL_EXIT immediately (bypass EMA lag)
ETM_COOLDOWN_LONG_THRESH=0.65      # raw exitScore above this after REDUCE_50 → long cooldown (5 cycles)

# ─── Entry Confirmation ───────────────────────────────────────────────────────
MOMENTUM_CONFIRM_CYCLES=5         # funding must stay above threshold for N×15s cycles before entry

# ─── Funding Settlement Timing ────────────────────────────────────────────────
SETTLEMENT_CAPTURE_WINDOW_MS=900000   # 15 min capture window before 8h settlement

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info                     # info | debug | warn | error

# ─── Notifications (optional) ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=                # leave blank to disable
TELEGRAM_CHAT_ID=
