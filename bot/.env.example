# ─── Helius RPC ───────────────────────────────────────────────────────────────
# Get your key at https://helius.dev
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
HELIUS_WS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY

# ─── Wallet ───────────────────────────────────────────────────────────────────
# Path to your Solana keypair JSON file (array of bytes)
# NEVER commit this file or this .env to git
WALLET_KEYPAIR_PATH=./keypair.json

# ─── Drift ────────────────────────────────────────────────────────────────────
DRIFT_PROGRAM_ID=dRiftyHA39MWEi3m9aunc5MzRF1JYuBsbn6VPcn33UH

# ─── Bot config ───────────────────────────────────────────────────────────────
# Maximum capital to deploy per asset (USD)
MAX_POSITION_SIZE_USD=40000

# Minimum funding rate to enter delta-neutral (decimal, e.g. 0.0001 = 0.01%/hr)
FUNDING_RATE_THRESHOLD=0.0001

# Minimum basis spread to enter basis trade (decimal, e.g. 0.01 = 1%)
BASIS_SPREAD_THRESHOLD=0.01

# ─── Notifications (optional) ─────────────────────────────────────────────────
# Telegram bot for risk alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
